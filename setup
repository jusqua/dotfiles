#!/bin/sh
set -eu

# Get functions and variables
for file in $(ls .setup); do
  . ".setup/$file"
done

# Verify packages
verify_packages requirements.txt

# Confirm overriding
confirm_override

# Git
link .gitconfig $HOME

# Neovim
link nvim $CONFIG

# Fish
link fish $CONFIG

# Alacritty
link alacritty $CONFIG


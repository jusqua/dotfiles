#!/bin/sh
# Abort current script
abort() {
  echo "Aborting."
  exit 1
}

# Get user confirmation about something
confirm() {
  read -p "$1 [y/N] " confirm
  case $confirm in
    [yY][eE][sS]|[yY]) break;;
    *) abort;;
  esac
}

# Link a file or directory to that selected path
link() {
  printf "Linking $1 to $2... "
  exec rm -rf "$2/$1" &
  wait
  exec ln -nsf "$PWD/$1" $2 &
  wait
  echo "Done"
}

# Function that loop through a file and verifies if a program exists
verify_packages() {
  missing=""
  
  printf "Verifing required packages are avaliable... "
  while read program; do
    command -v $program > /dev/null 2>&1 || missing="$program $missing"
  done < $1
  echo "Done"

  if [ "$missing" != "" ]; then
    echo "Missing packages: $missing"
    confirm "Do you want to setup anyway?"
  fi
}

